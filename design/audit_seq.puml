@startuml



actor UI
participant ApplicationListController
participant ApplicationListServiceImpl
participant AuditOperationServiceImpl
participant DataAuditLogger
participant AuditOperationSlf4jLogger
participant Reflect

UI->ApplicationListController : Http Post Create App List
activate  ApplicationListController
ApplicationListController -> ApplicationListServiceImpl : create(ApplicationListCreateDto dto)
activate  ApplicationListServiceImpl

ApplicationListServiceImpl -> AuditOperationServiceImpl : processAudit(oldValue, auditType, execution, listener)
activate  AuditOperationServiceImpl

AuditOperationServiceImpl -> AuditOperationSlf4jLogger : started(StartEvent event)
activate  AuditOperationSlf4jLogger

AuditOperationServiceImpl -> AuditOperationSlf4jLogger : finished(StartEvent event)

AuditOperationServiceImpl -> DataAuditLogger : finished(CompleteEvent event)
AuditOperationServiceImpl -> DataAuditLogger : started(StartEvent event)

AuditOperationServiceImpl -> DataAuditLogger : finished(CompleteEvent event)
activate  DataAuditLogger

group Manage Differences
DataAuditLogger -> ReflectiveAuditDifferentiator : diff(auditCrudOp, oldValue, newValue)
    loop for all differences detected


activate  ReflectiveAuditDifferentiator

database ApplicationListRepository


database DataAuditRepository

DataAuditLogger -> DataAuditRepository : Create Audit Record
activate  DataAuditRepository
    end
end
ApplicationListServiceImpl -> ApplicationListRepository : Create Record
activate  ApplicationListRepository

